# Caddy reverse proxy for the ssmtp-server dashboard.
# Automatic Let's Encrypt issuance + renewal. Certs persist in the caddy_data
# volume and survive container rebuilds, so updates never re-issue.

{
	email {$ACME_EMAIL}
	# Staging or production ACME directory, chosen by install.sh via ACME_CA.
	acme_ca {$ACME_CA}
}

{$MAIL_HOSTNAME} {
	encode gzip
	reverse_proxy web:8000
}

# Bare domain -> console. Needs an A record for the apex pointing at this
# server; if the apex is hosted elsewhere, Caddy just logs failed cert
# attempts for it and the console site above keeps working.
{$MAIL_DOMAIN} {
	redir https://{$MAIL_HOSTNAME}{uri} permanent
}
