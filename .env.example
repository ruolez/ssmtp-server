# ssmtp-server configuration
# install.sh generates a real .env from these values at install time.
# Copy to .env for local development: cp .env.example .env

# ----- Identity -----------------------------------------------------------
# Public hostname of this mail server (must have an A record + matching PTR).
MAIL_HOSTNAME=mail.example.com
# Default sending domain (used for DKIM/SPF/DMARC scaffolding).
MAIL_DOMAIN=example.com
# Public IPv4 of the VPS (used in the generated SPF record).
SERVER_IP=203.0.113.10

# ----- Web admin UI -------------------------------------------------------
ADMIN_USERNAME=admin
# For local dev only. install.sh prompts for a real password and hashes it.
ADMIN_PASSWORD=changeme
# Flask session signing key. install.sh generates a random one.
SECRET_KEY=dev-only-insecure-change-me

# Shared secret for Haraka -> Flask internal event API. install.sh randomizes.
INTERNAL_SECRET=dev-only-internal-secret-change-me

# ----- PostgreSQL ---------------------------------------------------------
POSTGRES_USER=ssmtp
POSTGRES_PASSWORD=ssmtp-dev-password
POSTGRES_DB=ssmtp
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ----- TLS / Let's Encrypt ------------------------------------------------
# Email used for the ACME account / expiry notices.
ACME_EMAIL=admin@example.com
# ACME directory URL. install.sh sets this based on a staging/production prompt.
#   Staging (test, untrusted certs, high rate limits):
#     https://acme-staging-v02.api.letsencrypt.org/directory
#   Production (real trusted certs, ~5 duplicate certs/week limit):
#     https://acme-v02.api.letsencrypt.org/directory
ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory

# ----- Web UI exposure ----------------------------------------------------
# Host port for plain-HTTP access to the dashboard when NOT using Caddy/TLS
# (local dev). In production Caddy serves 443 and this is unused.
WEB_DEV_PORT=8025
